    model.eval()

    test_root = Path("teseting Dataset")
    images = sorted(list_images(test_root))

    word = ""
    for img in images:
        x = load_image_tensor(img).unsqueeze(0).to(device)
        with torch.no_grad():
            pred = model(x).argmax(1).item()
        word += LABELS[pred]
        print(img.name, "->", LABELS[pred])
    
