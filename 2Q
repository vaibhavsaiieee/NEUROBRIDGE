# -------------------------
# GLOBAL CONFIG
# -------------------------
LABELS = [chr(ord("A") + i) for i in range(26)]
LBL2ID = {c: i for i, c in enumerate(LABELS)}

# -------------------------
# UTILITIES
# -------------------------
def set_seed(seed=42):
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)

def get_device():
    if torch.cuda.is_available():
        return torch.device("cuda")
    if hasattr(torch.backends, "mps") and torch.backends.mps.is_available():
        return torch.device("mps")
    return torch.device("cpu")

def list_images(root: Path):
    return [p for p in root.rglob("*") if p.suffix.lower() in [".png", ".jpg", ".jpeg"]]

def infer_label(path: Path):
    return LBL2ID[path.parent.name.upper()]

# -------------------------
# EEG IMAGE PREPROCESSING
# -------------------------
def load_image_tensor(path: Path, img_size=224):
    img = Image.open(path).convert("L")
    img = img.resize((img_size, img_size))
    arr = np.array(img).astype(np.float32)

    # 🔬 EEG preprocessing
    arr = cv2.medianBlur(arr, 3)
    arr = cv2.GaussianBlur(arr, (5, 5), 0)
    arr = (arr - arr.mean()) / (arr.std() + 1e-6)
    arr = np.clip(arr, -3, 3)
    arr = (arr + 3) / 6.0

    arr = arr[None, ...]
    return torch.from_numpy(arr)

# -------------------------
# DATASET
# -------------------------
class EEGDataset(Dataset):
    def __init__(self, items, img_size=224, train=False):
        self.items = items
        self.img_size = img_size
        self.train = train

    def __len__(self):
        return len(self.items)

    def __getitem__(self, idx):
        path, label = self.items[idx]
        x = load_image_tensor(path, self.img_size)
        return x, label

# -------------------------
# QUANTUM LAYER (FIXED)
# -------------------------
class QuantumLayer(nn.Module):
    def __init__(self, n_qubits=4, n_layers=2, n_inputs=12, q_out=16):
        super().__init__()

        if qml is None:
            self.classical = nn.Linear(n_inputs, q_out)
            self.mode = "classical"
            return

        self.dev = qml.device("default.qubit", wires=n_qubits)
        self.mode = "quantum"

        @qml.qnode(self.dev, interface="torch", diff_method="backprop")
        def circuit(inputs, weights):
            for i in range(n_qubits):
                qml.RX(inputs[i % inputs.shape[0]] * math.pi, wires=i)

            for l in range(n_layers):
                for q in range(n_qubits):
                    qml.Rot(*weights[l, q], wires=q)
                for q in range(n_qubits - 1):
                    qml.CNOT(wires=[q, q + 1])

            return [qml.expval(qml.PauliZ(i)) for i in range(n_qubits)]

        self.qlayer = qml.qnn.TorchLayer(
            circuit, {"weights": (n_layers, n_qubits, 3)}
        )
        self.post = nn.Linear(n_qubits, q_out)

    def forward(self, x):
        if self.mode == "classical":
            return torch.tanh(self.classical(x))

        outs = []
        for i in range(x.shape[0]):
            outs.append(self.qlayer(x[i]))
        stacked = torch.stack(outs)
        return torch.tanh(self.post(stacked))

# -------------------------
# FULL MODEL
# -------------------------
class QuantumEEGNet(nn.Module):
    def __init__(self):
        super().__init__()
        self.encoder = nn.Sequential(
            nn.Flatten(),
            nn.Linear(224 * 224, 64),
            nn.ReLU(),
            nn.Linear(64, 12),
            nn.Tanh()
        )
        self.quantum = QuantumLayer()
        self.head = nn.Sequential(
            nn.Linear(16, 64),
            nn.ReLU(),
            nn.Linear(64, 26)
        )

    def forward(self, x):
        z = self.encoder(x)
        q = self.quantum(z)
        return self.head(q)

# -------------------------
# TRAIN
# -------------------------
def train(args):
    device = get_device()
    print("Using device:", device)

    root = Path("training dataset")
    paths = list_images(root)
    random.shuffle(paths)

    split = int(0.85 * len(paths))
    train_items = [(p, infer_label(p)) for p in paths[:split]]
    val_items = [(p, infer_label(p)) for p in paths[split:]]

    dl_tr = DataLoader(EEGDataset(train_items, train=True),
                       batch_size=args.batch, shuffle=True)
    dl_va = DataLoader(EEGDataset(val_items),
                       batch_size=args.batch)

    model = QuantumEEGNet().to(device)
    opt = torch.optim.Adam(model.parameters(), lr=args.lr)
    loss_fn = nn.CrossEntropyLoss()

    best_acc = 0

    for ep in range(1, args.epochs + 1):
        model.train()
        total_loss = 0

        for x, y in dl_tr:
            x, y = x.to(device), y.to(device)
            opt.zero_grad()
            logits = model(x)
            loss = loss_fn(logits, y)
            loss.backward()
            opt.step()
            total_loss += loss.item()

        model.eval()
        correct = 0
        total = 0
        with torch.no_grad():
            for x, y in dl_va:
                x, y = x.to(device), y.to(device)
                preds = model(x).argmax(1)
                correct += (preds == y).sum().item()
                total += y.size(0)

        acc = correct / total
        print(f"Epoch {ep:03d} | Loss {total_loss:.4f} | Val Acc {acc:.4f}")

        if acc > best_acc:
            best_acc = acc
            torch.save(model.state_dict(), "modells/quantum_best.pt")

    print("Training done. Best Val Acc:", best_acc)

