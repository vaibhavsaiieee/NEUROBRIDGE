# -*- coding: utf-8 -*-
"""
Quantum-hybrid EEG Waveform A–Z Classifier (Single-File)
- Usage same as original:
    python3 main.py train
    python3 main.py test
- This file uses PennyLane as a quantum layer within a PyTorch model.
- Important: install dependencies:
    pip install torch pennylane pennylane-qiskit numpy pillow
"""

import os, argparse, random, math
from pathlib import Path
from typing import List, Tuple, Dict
import numpy as np
from PIL import Image

import torch
from torch import nn
from torch.utils.data import Dataset, DataLoader

# ---------- Original helpers & config ----------
LABELS = [chr(ord('A') + i) for i in range(26)]
LBL2ID = {c: i for i, c in enumerate(LABELS)}

def set_seed(seed=42):
    import numpy as _np, random as _random
    _random.seed(seed); _np.random.seed(seed)
    torch.manual_seed(seed); torch.cuda.manual_seed_all(seed)

def infer_label_from_path(p: Path) -> str:
    parent = p.parent.name.upper()
    if parent in LBL2ID:
        return parent
    stem = p.stem.upper()
    if stem and stem[0] in LBL2ID:
        return stem[0]
    raise ValueError(f"Cannot infer label for: {p}")

def list_images(root: Path) -> List[Path]:
    exts = {".png", ".jpg", ".jpeg", ".bmp"}
    return sorted([p for p in root.rglob("*") if p.suffix.lower() in exts])

def split_stratified(paths: List[Path], val_ratio=0.15):
    by_lbl: Dict[str, List[Path]] = {c: [] for c in LABELS}
    for p in paths:
        try:
            lbl = infer_label_from_path(p)
            by_lbl[lbl].append(p)
        except Exception:
            pass
    train, val = [], []
    for c in LABELS:
        L = by_lbl[c]
        random.shuffle(L)
        n = len(L)
        if n == 0: continue
        n_val = max(1, int(n * val_ratio)) if n >= 2 else 0
        val += [(p, LBL2ID[c]) for p in L[:n_val]]
        train += [(p, LBL2ID[c]) for p in L[n_val:]]
    return train, val

def load_image_tensor(path: Path, img_size=224, to_gray=True):
    img = Image.open(path).convert("L" if to_gray else "RGB")
    img = img.resize((img_size, img_size), Image.BILINEAR)
    arr = np.array(img).astype(np.float32) / 255.0
    if to_gray:
        arr = arr[None, ...]          # (1,H,W)
    else:
        arr = np.transpose(arr, (2, 0, 1))  # (3,H,W)
    x = torch.from_numpy(arr)
    return x

# ---------- Dataset ----------
class EEGImageDataset(Dataset):
    def __init__(self, items: List[Tuple[Path, int]], img_size=224, gray=True, train=False):
        self.items = items
        self.img_size = img_size
        self.gray = gray
        self.train = train

    def __len__(self): return len(self.items)

    def _augment(self, x: torch.Tensor) -> torch.Tensor:
        if not self.train:
            return x
        if torch.rand(1).item() < 0.7:
            x = torch.clamp(x + 0.03 * torch.randn_like(x), 0.0, 1.0)
        if torch.rand(1).item() < 0.5:
            _, h, w = x.shape
            ch = int(0.2 * h); cw = int(0.2 * w)
            y0 = torch.randint(0, max(1, h - ch), (1,)).item()
            x0 = torch.randint(0, max(1, w - cw), (1,)).item()
            x[:, y0:y0 + ch, x0:x0 + cw] = 0
        return x

    def __getitem__(self, idx):
        path, y = self.items[idx]
        x = load_image_tensor(path, self.img_size, self.gray)
        x = self._augment(x)
        return x, y

# ---------- Quantum-hybrid model ----------
# PennyLane imports are local so that the file can still be imported if pennylane is missing,
# but training will assert the package is present.
try:
    import pennylane as qml
    from pennylane import numpy as qnp  # not used heavily, but available
except Exception as e:
    qml = None

class ClassicalEmbed(nn.Module):
    """
    Small classical embedding to compress image into a low-dim vector
    suitable to feed into a quantum circuit. Keeps training stable.
    """
    def __init__(self, img_ch=1, img_size=224, latent_dim=16):
        super().__init__()
        # small conv stack to reduce HxW -> small vector
        self.net = nn.Sequential(
            nn.Conv2d(img_ch, 8, 3, padding=1), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(8, 16, 3, padding=1), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(16, 32, 3, padding=1), nn.ReLU(), nn.AdaptiveAvgPool2d(1),
            nn.Flatten(), nn.Linear(32, latent_dim), nn.Tanh()
        )
    def forward(self, x): return self.net(x)

if qml is not None:
    class PennylaneQuantumLayer(nn.Module):
        """
        A PyTorch-wrapped PennyLane quantum layer. It expects a small real-valued
        vector of size `n_inputs` and returns a feature vector of size `q_output`.
        Implementation detail: we build a QNode with `n_qubits` and measure
        several expectation values to get q_output size.
        """
        def __init__(self, n_qubits=4, n_layers=2, n_inputs=8, q_output=16, backend="default.qubit"):
            super().__init__()
            self.n_qubits = n_qubits
            self.n_layers = n_layers
            self.n_inputs = n_inputs
            self.q_output = q_output

            # create a device
            self.dev = qml.device(backend, wires=self.n_qubits)

            # Weight shapes for the variational circuit parameters
            # we will use rotations parameterized by weights per layer/per qubit
            weight_shapes = {"weights": (self.n_layers, self.n_qubits, 3)}

            # Build a QNode that returns multiple expectation values (one per measurement)
            @qml.qnode(self.dev, interface="torch", diff_method="backprop")
            def circuit(inputs, weights):
                # inputs: size n_inputs -> we will encode into rotation gates on first min(n_inputs, n_qubits)
                # simple angle embedding: map each input to rotation on a qubit
                for i in range(self.n_qubits):
                    angle = inputs[i % inputs.shape[0]] if inputs.shape[0] > 0 else 0.0
                    qml.RX(angle * math.pi, wires=i)
                # variational layers
                for l in range(self.n_layers):
                    for q in range(self.n_qubits):
                        qml.Rot(weights[l, q, 0], weights[l, q, 1], weights[l, q, 2], wires=q)
                    # entangle
                    for q in range(self.n_qubits - 1):
                        qml.CNOT(wires=[q, q + 1])
                # measure expectations - measure PauliZ on each qubit as features
                expvals = [qml.expval(qml.PauliZ(i)) for i in range(self.n_qubits)]
                # If q_output > n_qubits, we can tile or process with classical layer afterwards
                return qml.stack(expvals)

            # wrap QNode as a QLayer (keeps weights as torch parameters)
            self.qlayer = qml.qnn.TorchLayer(circuit, weight_shapes)
            # If we want q_output > n_qubits, follow with a classical linear map
            if q_output > self.n_qubits:
                self.post = nn.Linear(self.n_qubits, q_output)
            else:
                self.post = None

        def forward(self, x):
            # x is (B, n_inputs)
            outs = []
            for i in range(x.shape[0]):
                # qml TorchLayer expects 1D input; feeding one sample at a time works but is slower.
                out = self.qlayer(x[i])
                outs.append(out)
            stacked = torch.stack(outs, dim=0)
            if self.post is not None:
                return torch.tanh(self.post(stacked))
            return stacked
else:
    PennylaneQuantumLayer = None

class QuantumHybridModel(nn.Module):
    """
    Full hybrid model:
      image -> small classical embed -> quantum layer -> classical head -> logits
    """
    def __init__(self, num_classes=26, img_ch=1, img_size=224,
                 latent_dim=8, n_qubits=4, n_layers=2, q_output=16):
        super().__init__()
        self.embed = ClassicalEmbed(img_ch, img_size, latent_dim)
        if PennylaneQuantumLayer is None:
            raise RuntimeError("PennyLane not found. Install pennylane to use QuantumHybridModel.")
        self.q_layer = PennylaneQuantumLayer(n_qubits=n_qubits, n_layers=n_layers,
                                             n_inputs=latent_dim, q_output=q_output)
        self.head = nn.Sequential(nn.Linear(q_output, 64), nn.ReLU(), nn.Dropout(0.3),
                                  nn.Linear(64, num_classes))

    def forward(self, x):
        # x: (B,1,H,W)
        z = self.embed(x)          # (B, latent_dim)
        qf = self.q_layer(z)       # (B, q_output)
        logits = self.head(qf)     # (B, num_classes)
        return logits

# ---------- Training & test loops (adapted) ----------
def build_model(arch: str, num_classes=26, in_ch=1, img=224, qparams=None):
    # arch ignored: we only offer hybrid quantum here; keep to preserve CLI
    if arch not in ["quantum", "qhybrid", "cnn_transformer", "cnn", "cnn_lstm"]:
        raise ValueError("arch must be 'quantum' or 'qhybrid' for this file.")
    # set qparams defaults
    qparams = qparams or {}
    model = QuantumHybridModel(num_classes=num_classes,
                               img_ch=in_ch,
                               img_size=img,
                               latent_dim=qparams.get("latent_dim", 8),
                               n_qubits=qparams.get("n_qubits", 4),
                               n_layers=qparams.get("n_layers", 2),
                               q_output=qparams.get("q_output", 16))
    return model

def train(args):
    assert qml is not None, "PennyLane is required. Install via `pip install pennylane`."
    device = "cuda" if torch.cuda.is_available() else "cpu"
    print(f"Using {device} | quantum hybrid arch | backend=default.qubit (simulator)")

    train_root = Path("training dataset")
    assert train_root.exists(), "training dataset/ not found"

    paths = list_images(train_root)
    assert len(paths) > 0, "No images in training dataset/"
    train_items, val_items = split_stratified(paths, val_ratio=0.15)

    in_ch = 1
    ds_tr = EEGImageDataset(train_items, img_size=args.img, gray=True, train=True)
    ds_va = EEGImageDataset(val_items, img_size=args.img, gray=True, train=False)

    pin_mem = (device == "cuda")
    dl_tr = DataLoader(ds_tr, batch_size=args.batch, shuffle=True, num_workers=2, pin_memory=pin_mem)
    dl_va = DataLoader(ds_va, batch_size=args.batch, shuffle=False, num_workers=2, pin_memory=pin_mem)

    qparams = {"latent_dim": args.latent_dim, "n_qubits": args.n_qubits, "n_layers": args.n_layers, "q_output": args.q_output}
    model = build_model("quantum", num_classes=26, in_ch=in_ch, img=args.img, qparams=qparams).to(device)

    # Optimizer & loss
    opt = torch.optim.Adam(model.parameters(), lr=args.lr, weight_decay=0.01)
    sched = torch.optim.lr_scheduler.ReduceLROnPlateau(opt, patience=5, factor=0.7, verbose=True)
    criterion = nn.CrossEntropyLoss()
    scaler = torch.cuda.amp.GradScaler(enabled=(device == "cuda"))

    best_acc, bad, patience = 0.0, 0, 20
    models_dir = Path("modells"); models_dir.mkdir(exist_ok=True, parents=True)
    ckpt_path = models_dir / "best_quantum.pt"

    print(f"Train: {len(ds_tr)} | Val: {len(ds_va)} | Saving to {ckpt_path}")
    for ep in range(1, args.epochs + 1):
        model.train()
        loss_sum = 0.0
        for x, y in dl_tr:
            x, y = x.to(device, non_blocking=True), y.to(device, non_blocking=True)
            opt.zero_grad(set_to_none=True)
            with torch.cuda.amp.autocast(enabled=(device == "cuda")):
                logits = model(x)
                loss = criterion(logits, y)
            scaler.scale(loss).backward()
            scaler.step(opt); scaler.update()
            loss_sum += loss.item()
        # validate
        model.eval()
        tot = 0; correct = 0; val_loss = 0.0
        with torch.no_grad():
            for x, y in dl_va:
                x, y = x.to(device), y.to(device)
                logits = model(x)
                val_loss += criterion(logits, y).item()
                pred = logits.argmax(1)
                correct += (pred == y).sum().item()
                tot += y.size(0)
        acc = correct / max(1, tot)
        avg_train_loss = loss_sum / max(1, len(dl_tr))
        avg_val_loss = val_loss / max(1, len(dl_va))
        print(f"Epoch {ep:03d}/{args.epochs}  train_loss={avg_train_loss:.4f}  val_loss={avg_val_loss:.4f}  val_acc={acc:.4f}")

        sched.step(avg_val_loss)

        if acc > best_acc:
            best_acc, bad = acc, 0
            torch.save({"model": model.state_dict(), "qparams": qparams}, ckpt_path)
            print(f"[Checkpoint] {ckpt_path}  (val_acc={best_acc:.4f})")
        else:
            bad += 1
            if bad >= patience:
                print("Early stopping (patience reached).")
                break

    print(f"Training done. Best val acc = {best_acc:.4f}")

def predict_folder(args):
    assert qml is not None, "PennyLane is required for inference."
    device = "cuda" if torch.cuda.is_available() else "cpu"
    models_dir = Path("modells")
    ckpt_path = models_dir / "best_quantum.pt"
    assert ckpt_path.exists(), f"Checkpoint not found: {ckpt_path}. Train first."

    test_root = Path("teseting Dataset")
    assert test_root.exists(), "teseting Dataset/ not found"

    ckpt = torch.load(ckpt_path, map_location=device)
    qparams = ckpt.get("qparams", {"latent_dim": 8, "n_qubits": 4, "n_layers": 2, "q_output": 16})
    model = build_model("quantum", 26, in_ch=1, img=args.img, qparams=qparams).to(device).eval()
    model.load_state_dict(ckpt["model"], strict=False)

    test_imgs = list_images(test_root)
    test_imgs.sort(key=lambda p: p.name.lower())

    predicted_letters = []
    for p in test_imgs:
        x = load_image_tensor(p, img_size=args.img, to_gray=True)
        x = x.unsqueeze(0).to(device)
        with torch.no_grad():
            logits = model(x)[0].detach().cpu().numpy()
            probs = np.exp(logits - logits.max())
            probs = probs / probs.sum()
            idx = int(np.argmax(probs))
            letter = LABELS[idx]
            conf = float(probs[idx] * 100.0)
        print(f"[Predict] {p} → {letter} ({conf:.2f}%)")
        predicted_letters.append(letter)
    word = "".join(predicted_letters)
    print("\nFinal Predicted Word:", word)

# ---------- CLI ----------
def parse_args():
    ap = argparse.ArgumentParser(description="Train & Test Quantum-hybrid EEG A–Z classifier")
    ap.add_argument("mode", choices=["train", "test"], help="train or test")
    ap.add_argument("--epochs", type=int, default=60)
    ap.add_argument("--batch", type=int, default=8)
    ap.add_argument("--img", type=int, default=224)
    ap.add_argument("--lr", type=float, default=3e-4)
    ap.add_argument("--arch", choices=["quantum","qhybrid"], default="quantum")
    # quantum-specific params
    ap.add_argument("--n_qubits", type=int, default=4)
    ap.add_argument("--n_layers", type=int, default=2)
    ap.add_argument("--latent_dim", type=int, default=8)
    ap.add_argument("--q_output", type=int, default=16)
    return ap.parse_args()

def main():
    set_seed(42)
    args = parse_args()
    if args.mode == "train":
        train(args)
    else:
        predict_folder(args)

if __name__ == "__main__":
    main()

